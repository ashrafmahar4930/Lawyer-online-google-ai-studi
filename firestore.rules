rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS ---
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == 'admin@jurisconnect.com' ||
        request.auth.token.email.lower() == 'ashrafmahar4930@gmail.com'
      );
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTIONS ---
    
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    match /lawyers/{lawyerId} {
      allow read: if true;
      allow write: if isOwner(lawyerId) || isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewCount']));
    }
    
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /cases/{caseId} {
      allow read, write: if isAdmin() || (isSignedIn() && (
        request.auth.uid == resource.data.lawyerId || 
        request.auth.uid == request.resource.data.lawyerId
      ));
    }
    
    match /ledger/{entryId} {
      allow read, write: if isSignedIn(); 
    }
    
    match /articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /verifications/{requestId} {
      allow read, write: if isAdmin() || (isSignedIn() && (
        request.auth.uid == resource.data.lawyerId ||
        request.auth.uid == request.resource.data.lawyerId
      ));
    }
    
    match /blood_appeals/{appealId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.requesterId == request.auth.uid);
    }
    
    match /blood_donors/{donorId} {
      allow read: if true;
      allow write: if isOwner(donorId) || isAdmin();
    }
    
    match /questions/{questionId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.clientId == request.auth.uid);
    }
    
    match /answers/{answerId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.lawyerId == request.auth.uid);
    }
    
    match /notifications/{notificationId} {
      allow read, write: if isAdmin() || (isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == request.resource.data.userId ||
        resource.data.userId == 'lawyers' ||
        resource.data.userId == 'clients' ||
        resource.data.userId == 'all'
      ));
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
